<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>

    <key>CFBundleDisplayName</key>
    <string>GoalShare</string>

    <!-- HealthKit: purpose strings are required for App Store upload validation
         because the `health` plugin links HealthKit.framework. Reading only;
         the capability itself is enabled separately (see HealthService). -->
    <key>NSHealthShareUsageDescription</key>
    <string>GoalShare reads your activity from Apple Health — steps and calories burned on your iPhone and Apple Watch — to automatically track your exercise toward your daily goals.</string>
    <key>NSHealthUpdateUsageDescription</key>
    <string>GoalShare can record exercise you log back to Apple Health so your activity stays in sync.</string>

    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>

    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>

    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>

    <key>CFBundleName</key>
    <string>GoalShare</string>

    <key>CFBundlePackageType</key>
    <string>APPL</string>

    <key>CFBundleShortVersionString</key>
    <string>$(FLUTTER_BUILD_NAME)</string>

    <key>CFBundleSignature</key>
    <string>????</string>

    <key>CFBundleVersion</key>
    <string>$(FLUTTER_BUILD_NUMBER)</string>

    <key>LSRequiresIPhoneOS</key>
    <true/>

    <key>UILaunchStoryboardName</key>
    <string>LaunchScreen</string>

    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>

    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>

    <key>UIApplicationSupportsIndirectInputEvents</key>
    <true/>

    <!-- UIScene lifecycle. Our SceneDelegate builds the window with a plain
         placeholder first, then creates the FlutterViewController one run-loop
         turn LATER (deferred) — by which time the explicit engine's platform
         task runner is ready. That avoids the ProMotion launch crash in
         createTouchRateCorrectionVSyncClientIfNeeded / VSyncClient (#183900).
         No storyboard view controller is used. -->
    <key>UIApplicationSceneManifest</key>
    <dict>
        <key>UIApplicationSupportsMultipleScenes</key>
        <false/>
        <key>UISceneConfigurations</key>
        <dict>
            <key>UIWindowSceneSessionRoleApplication</key>
            <array>
                <dict>
                    <key>UISceneClassName</key>
                    <string>UIWindowScene</string>
                    <key>UISceneDelegateClassName</key>
                    <string>$(PRODUCT_MODULE_NAME).SceneDelegate</string>
                    <key>UISceneConfigurationName</key>
                    <string>flutter</string>
                </dict>
            </array>
        </dict>
    </dict>

    <!-- Camera Permission -->
    <key>NSCameraUsageDescription</key>
    <string>GoalShare uses the camera to let you upload progress photos for your goals.</string>

    <!-- Photo Library Read Permission -->
    <key>NSPhotoLibraryUsageDescription</key>
    <string>GoalShare needs access to your photo library so you can select and upload images.</string>

    <!-- Photo Library Write Permission -->
    <key>NSPhotoLibraryAddUsageDescription</key>
    <string>GoalShare saves images to your gallery when you download or export content.</string>

    <!-- Push notifications: allow the app to be woken to process a remote
         notification (FCM). Required alongside the aps-environment entitlement
         in Runner.entitlements. -->
    <key>UIBackgroundModes</key>
    <array>
        <string>remote-notification</string>
    </array>

    <!-- Encryption compliance — app uses only standard HTTPS, no custom encryption -->
    <key>ITSAppUsesNonExemptEncryption</key>
    <false/>

</dict>
</plist>