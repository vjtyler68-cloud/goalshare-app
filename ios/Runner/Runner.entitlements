<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Push Notifications capability. "development" is correct here: when the
	     app is archived and signed with an App Store / TestFlight distribution
	     profile, Xcode automatically promotes this to the production APNs
	     environment. FCM (with the uploaded .p8 key) delivers to whichever
	     environment the token registered under, so both work. -->
	<key>aps-environment</key>
	<string>development</string>
</dict>
</plist>
